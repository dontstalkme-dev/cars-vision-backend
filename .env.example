NODE_ENV=development
PORT=5000

# Database — Option 1 : URL unique (recommandé pour la production / Neon / Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Database — Option 2 : variables individuelles (développement local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carsvisionauto
DB_USER=postgres
DB_PASSWORD=your_password

# JWT - PHASE 2.4 : Secrets cryptographiquement sécurisés
# IMPORTANT : Générer des secrets de 64+ caractères aléatoires en production
# Exemple de génération : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_key_change_in_production_minimum_64_chars_recommended
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_minimum_64_chars_recommended
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Email (à configurer selon votre service)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@carsvisionauto.cm

# App
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
