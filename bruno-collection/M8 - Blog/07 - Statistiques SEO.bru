meta {
  name: 07 - Statistiques SEO
  type: http
  seq: 7
}

get {
  url: {{base_url}}/api/blog/admin/stats
  body: none
  auth: bearer
}

auth:bearer {
  token: {{admin_access_token}}
}

tests {
  test("Status should be 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Message should be correct", function() {
    expect(res.body.message).to.equal("Statistiques SEO");
  });
  
  test("Should have data", function() {
    expect(res.body.data).to.exist;
  });
}
