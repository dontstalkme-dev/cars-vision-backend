meta {
  name: 02 - Voir Article
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/blog/article-slug
  body: none
  auth: none
}

tests {
  test("Status should be 200 or 404", function() {
    expect([200, 404]).to.include(res.status);
  });
  
  test("If found, should have article data", function() {
    if (res.status === 200) {
      expect(res.body.data).to.exist;
      expect(res.body.data.titre).to.exist;
    }
  });
}
