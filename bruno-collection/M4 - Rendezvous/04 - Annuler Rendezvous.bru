meta {
  name: 04 - Annuler Rendezvous
  type: http
  seq: 4
}

put {
  url: {{base_url}}/api/appointments/{{rendezvous_id}}/cancel
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("Status should be 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Message should be success", function() {
    expect(res.body.message).to.include("Rendez-vous annulé");
  });
}
