meta {
  name: 04 - Sitemap XML
  type: http
  seq: 4
}

get {
  url: {{base_url}}/api/seo/sitemap.xml
  body: none
  auth: none
}

tests {
  test("Status should be 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Content-Type should be XML", function() {
    expect(res.headers['content-type']).to.include('xml');
  });
  
  test("Should contain urlset", function() {
    expect(res.body).to.include('urlset');
  });
}
