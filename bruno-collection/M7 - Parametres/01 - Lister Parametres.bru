meta {
  name: 01 - Lister Parametres
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/admin/parametres
  body: none
  auth: bearer
}

auth:bearer {
  token: {{admin_access_token}}
}

tests {
  test("Status should be 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Message should be correct", function() {
    expect(res.body.message).to.equal("Liste des paramètres");
  });
  
  test("Data should be array", function() {
    expect(res.body.data).to.be.an('array');
  });
}
