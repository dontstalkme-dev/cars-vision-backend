meta {
  name: 02 - Se Desabonner Newsletter
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/newsletter/unsubscribe
  body: json
  auth: none
}

body:json {
  {
    "email": "subscriber@example.com"
  }
}

tests {
  test("Status should be 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("Message should be success", function() {
    expect(res.body.message).to.equal("Désabonnement réussi");
  });
}
